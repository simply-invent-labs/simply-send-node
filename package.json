{
  "name": "simplysend",
  "version": "3.5.0",
  "description": "Official Node.js SDK for SimplySend - Send transactional and marketing emails",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --import tsx --test test/client.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "simplysend",
    "simply send",
    "email",
    "transactional",
    "marketing",
    "sdk",
    "node"
  ],
  "author": "Simply Send Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "ts-node": "^10.9.2",
    "tsup": "^6.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
